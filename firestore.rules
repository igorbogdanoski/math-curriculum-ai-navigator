rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Помошни функции ──────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ── Приватни Teacher податоци (lesson plans, planner, curriculum edits) ──
    match /users/{uid}/{collection=**} {
      allow read, write: if isOwner(uid);
    }

    // ── Квиз резултати (quiz_results) ────────────────────────────────────
    // Читање: јавно (ученик/родител ги гледа по ime без auth)
    // Создавање: анонимни ученици, задолжителни полиња
    // Ажурирање: само полето confidence (1-5) — за самооценување (П26)
    match /quiz_results/{doc} {
      allow read:   if true;
      allow create: if request.resource.data.keys().hasAll(['studentName', 'percentage', 'conceptId']);
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['confidence'])
                    && request.resource.data.confidence is int
                    && request.resource.data.confidence >= 1
                    && request.resource.data.confidence <= 5;
      allow delete: if false;
    }

    // ── Кеширани AI материјали (cached_ai_materials) ─────────────────────
    // Читање: сите (учениците читаат квизови преку линк без auth)
    // Пишување: само автентицирани наставници
    match /cached_ai_materials/{doc} {
      allow read:  if true;
      allow write: if isAuthenticated();
    }

    // ── Совладување на концепти (concept_mastery) ────────────────────────
    // Анонимни ученици пишуваат свој напредок, задолжителни полиња
    match /concept_mastery/{doc} {
      allow read:   if true;
      allow create: if request.resource.data.keys().hasAll(['studentName', 'conceptId']);
      allow update: if request.resource.data.keys().hasAll(['studentName', 'conceptId']);
      allow delete: if false;
    }

    // ── Заедничка библиотека на планови (communityLessonPlans) ───────────
    match /communityLessonPlans/{doc} {
      allow read:  if true;
      allow write: if isAuthenticated();
    }

    // ── Гамификација (student_gamification) ──────────────────────────────
    // Анонимни ученици пишуваат свој XP/стрик, studentName мора да постои
    // Update: не смее да го смени studentName (заштита од прекривање)
    match /student_gamification/{doc} {
      allow read:   if true;
      allow create: if request.resource.data.keys().hasAll(['studentName']);
      allow update: if resource.data.studentName == request.resource.data.studentName;
      allow delete: if false;
    }

    // ── Групи на ученици (student_groups) ────────────────────────────────
    match /student_groups/{doc} {
      allow read, write: if isAuthenticated();
    }

    // ── Live сесии (live_sessions) ────────────────────────────────────────
    // Create: само автентицирани (наставник создава сесија)
    // Read: сите (ученик се приклучува по 4-знаковен код)
    // Update: сите — само ако сесијата не е завршена (status != 'ended')
    match /live_sessions/{doc} {
      allow read:   if true;
      allow create: if isAuthenticated();
      allow update: if resource.data.status != 'ended';
      allow delete: if isAuthenticated();
    }

    // ── Класи (classes) ───────────────────────────────────────────────────
    match /classes/{doc} {
      allow read, write: if isAuthenticated();
    }

    // ── Зачувани прашања (saved_questions) — П22 ─────────────────────────
    // Само наставникот-сопственик може да чита, создава и брише
    match /saved_questions/{doc} {
      allow read:   if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
      allow update: if false;
    }

    // ── Огласи (announcements) — П27 ─────────────────────────────────────
    // Наставникот создава/брише, учениците читаат јавно (по teacherUid)
    match /announcements/{doc} {
      allow read:   if true;
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
      allow update: if false;
    }

    // ── Сè друго: одбиено ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
