rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Помошни функции (Helper functions & RBAC) ──
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Fetch the user's document to check their role/school
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Check if user has specific role
    function isRole(expectedRole) {
      return isAuthenticated() && getUserData().role == expectedRole;
    }

    // Global admin can do anything
    function isAdmin() {
      return isRole('admin');
    }

    function isSchoolAdmin(schoolId) {
      return (isRole('school_admin') || isRole('admin')) && getUserData().schoolId == schoolId;
    }

    // Anonymous students (play quizzes without a teacher account)
    function isAnonymousStudent() {
      return isAuthenticated() && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    // Google-authenticated user (not anonymous)
    function isGoogleUser() {
      return isAuthenticated() && request.auth.token.firebase.sign_in_provider == 'google.com';
    }

    // Teacher owns the document by teacherUid field
    function isDocOwner() {
      return isAuthenticated() && resource.data.teacherUid == request.auth.uid;
    }

    // First-come-first-served device ownership, mirroring student_identity's own create
    // rule: if nobody has claimed this deviceId yet, allow it (nothing to violate yet); if
    // someone has, only that same auth uid may write under it.
    function ownsClaimedDevice(deviceId) {
      return !exists(/databases/$(database)/documents/student_identity/$(deviceId))
        || get(/databases/$(database)/documents/student_identity/$(deviceId)).data.anonymousUid == request.auth.uid;
    }

    // Read-side counterpart to ownsClaimedDevice(), for a caller who is NOT (or no longer)
    // anonymous — e.g. a student who linked their anonymous session to Google via
    // linkWithPopup(), which keeps the same Firebase Auth uid but flips
    // sign_in_provider away from 'anonymous', so isAnonymousStudent() alone stops
    // recognizing them even though they still own the same device/uid. Requires the
    // student_identity doc to actually exist and be bound to this uid — unclaimed devices
    // don't get read access this way (that's what isAnonymousStudent() is for, pre-link).
    function ownsDeviceViaIdentity(deviceId) {
      return exists(/databases/$(database)/documents/student_identity/$(deviceId))
        && get(/databases/$(database)/documents/student_identity/$(deviceId)).data.anonymousUid == request.auth.uid;
    }

    // Only anonymous-student writers need to prove device ownership. Teacher-authenticated
    // writes (isDocOwner()) legitimately reference a student's deviceId without the
    // teacher's own uid ever matching that device's anonymousUid, and lab/self-practice
    // writes have no deviceId field at all — both stay exempt, matching current behavior.
    function deviceOwnershipOk() {
      return !isAnonymousStudent()
        || !('deviceId' in request.resource.data)
        || ownsClaimedDevice(request.resource.data.deviceId);
    }

    // Integrity check for the optional studentUid field (Google-linked student sessions,
    // see ownsDeviceViaIdentity()) — if a write sets it, it must be the caller's own uid;
    // a caller can never stamp someone else's uid onto a mastery record. Absent is fine
    // (anonymous students and teacher-authored writes don't set this field at all).
    function studentUidOk() {
      return !('studentUid' in request.resource.data)
        || request.resource.data.studentUid == request.auth.uid;
    }

    // Cosmetic/leaderboard-integrity bound on student_gamification numeric fields — no
    // credits/PII at stake, just keeps a compromised client from writing absurd XP/streak values.
    function isValidGamificationNumbers() {
      return (!('totalXP' in request.resource.data) || (request.resource.data.totalXP is number && request.resource.data.totalXP >= 0 && request.resource.data.totalXP <= 1000000)) &&
        (!('currentStreak' in request.resource.data) || (request.resource.data.currentStreak is number && request.resource.data.currentStreak >= 0 && request.resource.data.currentStreak <= 3650)) &&
        (!('longestStreak' in request.resource.data) || (request.resource.data.longestStreak is number && request.resource.data.longestStreak >= 0 && request.resource.data.longestStreak <= 3650));
    }

    // concept_mastery numeric bounds — same "close the trivial fabricate-an-absurd-value case"
    // intent as isValidGamificationNumbers(), applied to bestScore/lastScore (percentages) and
    // the attempt counters. Each bound only applies when its field is present.
    function conceptMasteryScoresOk() {
      return (!('bestScore' in request.resource.data) || (request.resource.data.bestScore is number && request.resource.data.bestScore >= 0 && request.resource.data.bestScore <= 100)) &&
        (!('lastScore' in request.resource.data) || (request.resource.data.lastScore is number && request.resource.data.lastScore >= 0 && request.resource.data.lastScore <= 100)) &&
        (!('attempts' in request.resource.data) || (request.resource.data.attempts is number && request.resource.data.attempts >= 0)) &&
        (!('consecutiveHighScores' in request.resource.data) || (request.resource.data.consecutiveHighScores is number && request.resource.data.consecutiveHighScores >= 0));
    }

    // Forum: lets ANY authenticated user toggle only their own uid in a single string-array
    // field (upvotedBy / reactionsHelpful / reactionsSame / reactionsGreat) — add or remove
    // exactly one entry, exactly their own, with every other field and array member untouched.
    // Mirrors academic_annual_plans' existing likedByUid toggle pattern, generalized to any
    // field name since forum threads/replies each have four of these.
    function isSelfArrayToggle(field) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([field]) &&
        (
          (request.resource.data[field].size() == resource.data.get(field, []).size() + 1 &&
           request.resource.data[field].hasAll(resource.data.get(field, [])) &&
           request.resource.data[field].hasAny([request.auth.uid])) ||
          (request.resource.data[field].size() == resource.data.get(field, []).size() - 1 &&
           resource.data.get(field, []).hasAll(request.resource.data[field]) &&
           !request.resource.data[field].hasAny([request.auth.uid]))
        );
    }

    // Forum: lets ANY authenticated user bump a thread's reply-count bookkeeping when THEY
    // post a reply to it (createForumReply) — not just the thread's own author. Restricted to
    // exactly these 3 fields, replyCount incrementing by exactly 1, and the caller's own uid
    // being added to participantUids (never someone else's).
    function isForumReplyBump() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replyCount', 'lastActivityAt', 'participantUids']) &&
        request.resource.data.replyCount == resource.data.get('replyCount', 0) + 1 &&
        request.resource.data.participantUids.hasAll(resource.data.get('participantUids', [])) &&
        request.resource.data.participantUids.hasAny([request.auth.uid]);
    }

    // Forum: is the caller the AUTHOR of the thread a reply belongs to (not the reply's own
    // author) — markBestAnswer/toggleFeynmanBadge are the thread-asker's calls on OTHER
    // people's replies, not self-actions, so isDocOwner()-style checks don't apply here.
    function isForumThreadAuthorOf(threadId) {
      return exists(/databases/$(database)/documents/forum_threads/$(threadId))
        && get(/databases/$(database)/documents/forum_threads/$(threadId)).data.authorUid == request.auth.uid;
    }

    // Forum: lets any authenticated (non-admin) caller flag a thread for review —
    // touches ONLY moderationStatus/reportedBy/reportReason, forces moderationStatus to
    // 'pending' (can't self-approve through this branch), and reportedBy may only ever
    // gain exactly the caller's own uid (can't add/remove someone else's, can't clear it —
    // clearing is approveForumThread's job, admin-only).
    function isForumThreadReport() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['moderationStatus', 'reportedBy', 'reportReason']) &&
        request.resource.data.moderationStatus == 'pending' &&
        request.resource.data.reportedBy.size() == resource.data.get('reportedBy', []).size() + 1 &&
        request.resource.data.reportedBy.hasAll(resource.data.get('reportedBy', [])) &&
        request.resource.data.reportedBy.hasAny([request.auth.uid]);
    }

    // Same as isForumThreadReport() but for forum_replies, which has no moderationStatus
    // field of its own — reported replies are surfaced via a visible badge (see
    // ForumInternals.tsx) rather than a separate admin queue, with admin delete as the
    // resolution action.
    function isForumReplyReport() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reportedBy', 'reportReason']) &&
        request.resource.data.reportedBy.size() == resource.data.get('reportedBy', []).size() + 1 &&
        request.resource.data.reportedBy.hasAll(resource.data.get('reportedBy', [])) &&
        request.resource.data.reportedBy.hasAny([request.auth.uid]);
    }

    // Live sessions: a student may only ever write their OWN key inside studentResponses —
    // keyed by their anonymous Auth uid, not their display name (two students with the same
    // name used to silently overwrite each other's response before this fix) — never another
    // student's entry, and never any other top-level field (status/timerPerQuestion/etc. stay
    // host-only, checked separately via isOwner(resource.data.hostUid)).
    function isOwnLiveResponseWrite() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentResponses'])
        && request.resource.data.studentResponses.diff(resource.data.studentResponses).affectedKeys().hasOnly([request.auth.uid]);
    }

    // ── Кориснички профили (users) ──
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin() || (isAuthenticated() && resource.data.schoolId != null && isSchoolAdmin(resource.data.schoolId));

      // Prevent client-side manipulation of credits, subscription flags, and role —
      // matches the always-'teacher'/50-credit/'Free' shape written by every real
      // signup path in contexts/AuthContext.tsx. isAdmin() may still create any shape.
      allow create: if isAdmin() || (
        isOwner(uid) &&
        (!('role' in request.resource.data) || request.resource.data.role == 'teacher') &&
        (!('isPremium' in request.resource.data) || request.resource.data.isPremium == false) &&
        (!('hasUnlimitedCredits' in request.resource.data) || request.resource.data.hasUnlimitedCredits == false) &&
        (!('tier' in request.resource.data) || request.resource.data.tier == 'Free') &&
        (!('aiCreditsBalance' in request.resource.data) || request.resource.data.aiCreditsBalance <= 50)
      );
      allow update: if isAdmin() || (
        isOwner(uid) &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'aiCreditsBalance', 'tier', 'isPremium', 'hasUnlimitedCredits', 'role'
        ]))
      );
      allow delete: if isAdmin();

      // NOTE: {document=**} is a recursive wildcard that also matches ZERO segments —
      // i.e. it would ALSO match users/{uid} itself, silently overriding the field
      // restrictions on create/update above via `write` + isOwner(uid) with no field
      // scoping at all. Requiring one named segment before the recursive wildcard
      // scopes this to actual subcollections (material_feedback, maturaResults, etc.)
      // without re-opening the parent document. Verified via emulator test.
      match /{subcollection}/{document=**} {
        allow read, write: if isOwner(uid) || isAdmin();
      }
    }

    // ── Квиз резултати (quiz_results) ──
    // 2026-07-18 (audit_2026_07_18_full_app_review, security finding #1): the blanket
    // isAnonymousStudent() branch let ANY anonymous sign-in read the entire collection
    // unscoped (a query with no matching where() clause). Replaced with the same
    // deviceId-ownership pattern already used by concept_mastery — every real
    // student-facing read of this collection already supplies deviceId (see
    // StudentTutorView.tsx/LabExercisePanel.tsx/useLabSession.ts fixes from the same pass).
    match /quiz_results/{doc} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        isDocOwner() ||
        (resource.data.deviceId != null && ownsDeviceViaIdentity(resource.data.deviceId)) ||
        (resource.data.schoolId != null && isSchoolAdmin(resource.data.schoolId))
      );
      // Bounds only (mirrors dugga_submissions' pattern) — can't verify percentage is actually
      // correct for the real quiz without server-side re-grading, but closes the trivial
      // "fabricate an out-of-range value" case. correctCount/totalQuestions are bounded only
      // when both are present, since not every write path supplies them.
      allow create: if isAuthenticated()
                    && request.resource.data.keys().hasAll(['studentName', 'percentage', 'conceptId'])
                    && deviceOwnershipOk()
                    && request.resource.data.percentage is number
                    && request.resource.data.percentage >= 0 && request.resource.data.percentage <= 100
                    && (
                      !('correctCount' in request.resource.data) || !('totalQuestions' in request.resource.data) || (
                        request.resource.data.correctCount is number && request.resource.data.correctCount >= 0 &&
                        request.resource.data.totalQuestions is number && request.resource.data.totalQuestions >= 0 &&
                        request.resource.data.correctCount <= request.resource.data.totalQuestions
                      )
                    );
      // Allow students to self-assess (confidence 1-5) or save metacognitive notes — gated
      // by deviceOwnershipOk() so only the quiz's own device-bound student (or a teacher/
      // lab write with no deviceId) can set these, not any authenticated caller.
      allow update: if isAuthenticated() && deviceOwnershipOk() && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['confidence'])
          && request.resource.data.confidence is int
          && request.resource.data.confidence >= 1
          && request.resource.data.confidence <= 5
      ) || (
        isAuthenticated() && deviceOwnershipOk() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['metacognitiveNote'])
          && request.resource.data.metacognitiveNote is string
      );
      allow delete: if isDocOwner() || isAdmin(); // owning teacher needs this for GDPR self-service deletion
    }

    // ── Кеширани AI материјали (cached_ai_materials) ──
    // read: public by default — students (anonymous auth) must be able to play quizzes.
    //   isPrivate=true materials require authentication (teacher set them private).
    //   Anonymous students are Firebase anonymous-auth users, so isAuthenticated() passes them.
    // И3: any authenticated teacher may update ratingsByUid (dot-notation field)
    match /cached_ai_materials/{doc} {
      allow read:   if !resource.data.get('isPrivate', false) || isAuthenticated();
      // 2026-07-18 (audit_2026_07_18_full_app_review, security finding): create had no
      // ownership check at all — any authenticated caller (including anonymous students, who
      // legitimately create these via saveRemediaQuiz after a low quiz score) could stamp an
      // arbitrary teacherUid onto a new doc, impersonating that teacher's attribution. Mirrors
      // the update rule's own check just below: teacherUid may be omitted (anonymous-authored
      // remedial quizzes), but if present it must be the caller's own uid.
      allow create: if isAuthenticated() && (
        !('teacherUid' in request.resource.data) || request.resource.data.teacherUid == request.auth.uid
      );
      allow update: if isAuthenticated() && (
        !('teacherUid' in resource.data) || resource.data.teacherUid == request.auth.uid || isAdmin()
        // И3: peer rating — any authenticated user may set their own rating entry (1-5 only);
        // the diff() check on the nested map itself (not just the top-level field) ensures
        // no OTHER teacher's rating entry can be overwritten in the same call.
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ratingsByUid'])
          && request.resource.data.ratingsByUid.diff(resource.data.get('ratingsByUid', {})).affectedKeys().hasOnly([request.auth.uid])
          && request.resource.data.ratingsByUid[request.auth.uid] is int
          && request.resource.data.ratingsByUid[request.auth.uid] >= 1
          && request.resource.data.ratingsByUid[request.auth.uid] <= 5
        )
      );
      allow delete: if isAuthenticated() && (
        !('teacherUid' in resource.data) || resource.data.teacherUid == request.auth.uid || isAdmin()
      );
    }

    // ── Задачи (assignments) ──
    // 2026-07-18 (audit_2026_07_18_full_app_review, security finding #1): unlike quiz_results/
    // concept_mastery, this collection carries no deviceId/studentUid field at all — client
    // reads scope by `classStudentNames array-contains studentName` (hooks/useStudentRealtime.ts),
    // which a Firestore rule cannot verify against a bare anonymous auth token (no claim proves
    // "my name is in this array"). Closing this fully needs a device→teacherUid reverse-lookup
    // (custom claims or a mirror collection) — intentionally NOT built in this pass (Tier 2,
    // flagged as follow-up work). isAnonymousStudent() is left as-is here; it's the same
    // pre-existing blast radius as today, not made worse or better by this pass.
    match /assignments/{doc} {
      allow read: if isAuthenticated() && (
        isDocOwner() ||
        isAnonymousStudent() ||
        isAdmin() ||
        (resource.data.schoolId != null && isSchoolAdmin(resource.data.schoolId))
      );
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid;
      allow update: if isAuthenticated() && (
        isOwner(resource.data.teacherUid) ||
        // Student self-marking completion — narrowed to anonymous student sessions only
        // (still not scoped to "their own" assignment specifically; deviceId isn't
        // auth-verifiable under the current identity model, see class_memberships).
        (isAnonymousStudent() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['completedBy']))
      );
      allow delete: if isOwner(resource.data.teacherUid) || isAdmin();
    }

    match /worksheet_approvals/{doc} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        resource.data.teacherUid == request.auth.uid
      );
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid;
      allow update, delete: if isAuthenticated() && (
        isAdmin() ||
        resource.data.teacherUid == request.auth.uid
      );
    }

    // ── Совладување на концепти (concept_mastery) ──
    // 2026-07-18 (audit_2026_07_18_full_app_review, security finding #1): the blanket
    // isAnonymousStudent() branch (both read AND update) let ANY anonymous sign-in read or
    // overwrite ANY document in this collection — for update, deviceOwnershipOk() alone didn't
    // close this, since it trivially passes when the write simply omits deviceId. Removed from
    // both; every legitimate anonymous-student read/write already supplies deviceId or
    // studentUid (see fetchMasteryByStudent's own comment on this file, and
    // updateConceptMastery in firestoreService.quiz.ts, which always includes deviceId in the
    // payload when the caller has one). studentUid/ownsDeviceViaIdentity branches additionally
    // cover a student who has linked their anonymous session to Google (linkWithPopup keeps the
    // same uid but flips sign_in_provider away from 'anonymous').
    match /concept_mastery/{doc} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        isDocOwner() ||
        (resource.data.schoolId != null && isSchoolAdmin(resource.data.schoolId)) ||
        (resource.data.studentUid != null && resource.data.studentUid == request.auth.uid) ||
        (resource.data.deviceId != null && ownsDeviceViaIdentity(resource.data.deviceId))
      );
      // bestScore/lastScore bounded to 0-100 (and attempts/consecutiveHighScores to >= 0) only
      // when present — closes the trivial "fabricate an out-of-range value" case without
      // requiring every write path to supply every field (mirrors quiz_results' pattern).
      allow create: if isAuthenticated() && request.resource.data.keys().hasAll(['studentName', 'conceptId']) && deviceOwnershipOk()
                    && conceptMasteryScoresOk() && studentUidOk();
      // Only the owning teacher, a device/studentUid-verified student (anonymous or
      // Google-linked), or admin may update.
      allow update: if isAuthenticated() && (
        isDocOwner() ||
        isAdmin() ||
        (resource.data.studentUid != null && resource.data.studentUid == request.auth.uid) ||
        (resource.data.deviceId != null && ownsDeviceViaIdentity(resource.data.deviceId))
      ) && request.resource.data.keys().hasAll(['studentName', 'conceptId']) && deviceOwnershipOk()
        && conceptMasteryScoresOk() && studentUidOk();
      allow delete: if isDocOwner() || isAdmin(); // owning teacher needs this for GDPR self-service deletion
    }

    // ── Заедничка библиотека на планови (communityLessonPlans) ──
    // Migrated to scenario_bank (S102). Read-only — new content goes to scenario_bank.
    match /communityLessonPlans/{doc} {
      allow read:   if true;
      allow write:  if false;
    }

    // ── Гамификација (student_gamification) ──
    // 2026-07-18 (audit_2026_07_18_full_app_review, security finding #1): fetchClassLeaderboard
    // (hooks/useStudentProgress.ts) legitimately reads every classmate's doc under one teacherUid
    // (for rank) — a genuine cross-student read a deviceId/studentUid-scoped rule can't allow, so
    // isAnonymousStudent() can't simply be dropped here the way it was for quiz_results/
    // concept_mastery without breaking the leaderboard outright. A real fix needs a
    // device→teacherUid reverse-lookup (custom claims or a mirror collection) to let the rule
    // verify "this uid's class" without reading the whole collection — intentionally NOT built
    // in this pass (Tier 2, flagged as follow-up work, same as assignments/announcements below).
    match /student_gamification/{doc} {
      allow read: if isAuthenticated() && (
        isAnonymousStudent() ||
        isAdmin() ||
        !('teacherUid' in resource.data) ||
        isDocOwner() ||
        (resource.data.schoolId != null && isSchoolAdmin(resource.data.schoolId))
      );
      allow create: if isAuthenticated() && request.resource.data.keys().hasAll(['studentName']) && isValidGamificationNumbers() && deviceOwnershipOk();
      // Prevent changing studentName; only the anonymous student or teacher-owner may update
      allow update: if isAuthenticated() && (
        isAnonymousStudent() || isDocOwner() || isAdmin()
      ) && resource.data.studentName == request.resource.data.studentName && isValidGamificationNumbers() && deviceOwnershipOk();
      allow delete: if isDocOwner() || isAdmin(); // owning teacher needs this for GDPR self-service deletion
    }

    // ── Групи на ученици (student_groups) ──
    match /student_groups/{doc} {
      allow read: if isAuthenticated() && (isOwner(resource.data.teacherUid) || (resource.data.schoolId != null && isSchoolAdmin(resource.data.schoolId)) || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid;
      allow update, delete: if isOwner(resource.data.teacherUid) || isAdmin();
    }

    // ── Live сесии (live_sessions) ──
    // get: public — students need to read session by join code before they authenticate
    // list: authenticated only — prevents enumeration of all active sessions
    // update: the host (hostUid) can change anything (status/timerPerQuestion/etc.); any
    // other authenticated caller (students) may ONLY write their own uid-keyed entry inside
    // studentResponses — closes a prior gap where ANY authenticated caller could overwrite
    // ANY student's response on an active session (the old rule checked a nonexistent
    // `teacherUid` field — the real field is `hostUid` — so the owner-branch never actually
    // matched; fixed here too).
    match /live_sessions/{doc} {
      allow get:    if true;
      allow list:   if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isOwner(resource.data.hostUid) || isOwnLiveResponseWrite());
      allow delete: if isOwner(resource.data.hostUid) || isAdmin();
    }

    // ── Класови (classes) ──
    match /classes/{doc} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        isDocOwner() ||
        (resource.data.schoolId != null && isSchoolAdmin(resource.data.schoolId))
      );
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid;
      allow update, delete: if isOwner(resource.data.teacherUid) || isAdmin();
    }

    // ── Членство во класа (class_memberships) — И2 ──
    // Документ ID = deviceId на ученикот.
    // Ученикот (anonymous auth) може сам да ги чита/пишува своите.
    // Наставникот може да чита (за analytics).
    // doc ID = deviceId — now checked against student_identity/{deviceId}'s recorded
    // anonymousUid via ownsClaimedDevice() (same mechanism already used for quiz_results/
    // concept_mastery), instead of "any anonymous student session". First-come-first-served:
    // if no student_identity doc exists yet for this deviceId (e.g. live-PIN-join before the
    // first confirm completes), the write is still allowed — nothing to violate yet.
    match /class_memberships/{deviceDoc} {
      allow read, write: if (isAnonymousStudent() && ownsClaimedDevice(deviceDoc)) || isAdmin() ||
        (isAuthenticated() && resource.data.teacherUid == request.auth.uid);
    }

    // ── Зачувани прашања (saved_questions) ──
    match /saved_questions/{doc} {
      allow read:   if isAuthenticated() && (resource.data.teacherUid == request.auth.uid || isAdmin() || (resource.data.schoolId != null && isSchoolAdmin(resource.data.schoolId)));
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.teacherUid == request.auth.uid || isAdmin() || (resource.data.schoolId != null && isSchoolAdmin(resource.data.schoolId)));
      // Author may flip public/verified flags on their own question; admin/school_admin moderation
      // (ContentReviewView approve/revision-request flow) may set the full review field set.
      allow update: if isAuthenticated() && (
        (resource.data.teacherUid == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPublic', 'isVerified', 'verifiedAt'])) ||
        ((isAdmin() || (resource.data.schoolId != null && isSchoolAdmin(resource.data.schoolId))) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(
            ['isApproved', 'isVerified', 'isPublic', 'reviewStatus', 'reviewedBy', 'reviewedAt', 'reviewReasonCodes', 'reviewComments']
          ))
      );
    }

    // ── Глобални поставки за feature flags (app_config/featureFlags) — само global admin пишува ──
    match /app_config/{doc} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Огласи (announcements) ──
    // 2026-07-18 (audit_2026_07_18_full_app_review, security finding #1): client reads scope by
    // `where('teacherUid','==', teacherUid)` (hooks/useStudentRealtime.ts) — a shared class feed
    // a student legitimately needs to read (the teacher's broadcast, not their own document), but
    // a Firestore rule can't verify "this uid belongs to this teacherUid" from a bare anonymous
    // auth token. Same Tier 2 (device→teacherUid reverse-lookup) gap as assignments/
    // student_gamification above — intentionally NOT built in this pass, flagged as follow-up.
    match /announcements/{doc} {
      allow read: if isAuthenticated() && (
        isDocOwner() ||
        isAnonymousStudent() ||
        isAdmin() ||
        (resource.data.schoolId != null && isSchoolAdmin(resource.data.schoolId))
      );
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid;
      allow delete: if (isAuthenticated() && resource.data.teacherUid == request.auth.uid) || isAdmin();
      allow update: if isOwner(resource.data.teacherUid) || isAdmin();
    }

    // ── Училишта (schools) ──
    // Public read allowed — school list is needed for the registration form (unauthenticated)
    match /schools/{schoolId} {
      allow read: if true;
      allow write: if isAdmin();

      // {document=**} also matches zero segments (the schools/{schoolId} doc itself),
      // which would let a school_admin write to the root school doc (teacherUids/
      // adminUids) despite the explicit isAdmin()-only rule above. Scope to actual
      // subcollections only — see the identical fix + explanation under users/{uid}.
      match /{subcollection}/{document=**} {
        allow read: if isAuthenticated();
        allow write: if isSchoolAdmin(schoolId) || isAdmin();
      }
    }

    // ── Белешки на наставник по концепт (teacher_notes) ──
    match /teacher_notes/{docId} {
      allow read:   if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
      allow delete: if (isAuthenticated() && resource.data.teacherUid == request.auth.uid) || isAdmin();
    }

    // ── Идентитет на ученик (student_identity) ──
    // Document ID = deviceId. Only the owning anonymous user can read/write.
    match /student_identity/{deviceId} {
      allow read:   if isAuthenticated() && (
        request.auth.uid == resource.data.anonymousUid
      );
      allow create: if isAuthenticated() && request.resource.data.keys().hasAll(['deviceId', 'name', 'anonymousUid']) && request.resource.data.anonymousUid == request.auth.uid;
      allow update: if isAuthenticated() && request.auth.uid == resource.data.anonymousUid;
      allow delete: if isAdmin();
    }

    // ── Студентски акаунт (student_accounts) — С1 ──
    // Document ID = Google UID. Cross-device student profile.
    match /student_accounts/{uid} {
      // Only the owning Google-authenticated student or admin may read
      allow read:   if isOwner(uid) || isAdmin();
      // Only the authenticated user may create their own account doc
      allow create: if isOwner(uid) && isGoogleUser()
                    && request.resource.data.keys().hasAll(['name', 'linkedDeviceIds']);
      // Owner may update (add devices, change name); admin may update
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Годишни планови (academic_annual_plans) ──
    // Public gallery — all authenticated teachers can browse; owner can edit/delete.
    match /academic_annual_plans/{doc} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        // Like/unlike: caller may only ever add or remove their OWN uid from
        // likedByUid, one at a time (toggleAnnualPlanLike) — prevents inflating the
        // count for other users or removing someone else's like.
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedByUid']) &&
         (
           (request.resource.data.likedByUid.size() == resource.data.get('likedByUid', []).size() + 1 &&
            request.resource.data.likedByUid.hasAll(resource.data.get('likedByUid', [])) &&
            request.resource.data.likedByUid.hasAny([request.auth.uid])) ||
           (request.resource.data.likedByUid.size() == resource.data.get('likedByUid', []).size() - 1 &&
            resource.data.get('likedByUid', []).hasAll(request.resource.data.likedByUid) &&
            !request.resource.data.likedByUid.hasAny([request.auth.uid]))
         )) ||
        // Fork count: allow bumping by exactly +1 per call (matches the only client
        // usage, `increment(1)`) — constraining the delta prevents any authenticated
        // caller from setting the counter to an arbitrary value.
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['forks']) &&
         request.resource.data.forks == (resource.data.forks is number ? resource.data.forks : 0) + 1) ||
        isAdmin()
      );
      allow delete: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    // ── AI Концептуални карти (mind_maps) — приватни, само сопственикот ──
    match /mind_maps/{doc} {
      allow read:   if isAuthenticated() && (resource.data.teacherUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
      allow delete: if (isAuthenticated() && resource.data.teacherUid == request.auth.uid) || isAdmin();
    }

    // ── Математички изрази (math_expressions) — приватни, само сопственикот ──
    match /math_expressions/{doc} {
      allow read:   if isAuthenticated() && (resource.data.teacherUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
      allow delete: if (isAuthenticated() && resource.data.teacherUid == request.auth.uid) || isAdmin();
    }

    // ── AI Chat сесии (chat_sessions) ──
    // Private to the owning teacher.
    match /chat_sessions/{doc} {
      allow read:   if isAuthenticated() && (resource.data.teacherUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
      allow delete: if (isAuthenticated() && resource.data.teacherUid == request.auth.uid) || isAdmin();
    }

    // ── Интервали за повторување (spaced_rep) ──
    // Doc ID = {studentId}_{conceptId}. Written by anonymous student or teacher.
    match /spaced_rep/{doc} {
      // studentId here is actually the raw deviceId (see firestoreService.spacedRep.ts) —
      // ownsDeviceViaIdentity() covers a student who linked their anonymous session to
      // Google (same uid, but isAnonymousStudent() stops matching post-link).
      allow read:   if isAuthenticated() && (isAnonymousStudent() || isAdmin() || isDocOwner() || (resource.data.studentId != null && ownsDeviceViaIdentity(resource.data.studentId)));
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isAnonymousStudent() || isDocOwner() || isAdmin() || (resource.data.studentId != null && ownsDeviceViaIdentity(resource.data.studentId)));
      allow delete: if isDocOwner() || isAdmin(); // owning teacher needs this for GDPR self-service deletion
    }

    // ── Повратна информација за материјали (material_feedback) ──
    match /material_feedback/{doc} {
      allow read:   if isAuthenticated() && (resource.data.teacherUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
      allow delete: if isDocOwner() || isAdmin(); // owning teacher needs this for GDPR self-service deletion
    }

    // ── AI feedback telemetry (ai_material_feedback_events) ──
    // Events are written by the owning teacher and may be read by owner/admin for analytics + GDPR export.
    match /ai_material_feedback_events/{doc} {
      allow read:   if isAuthenticated() && (resource.data.teacherUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid;
      allow update: if false; // immutable event log
      allow delete: if isAdmin();
    }

    // ── Push нотификациски токени (user_tokens) ──
    // Doc ID = {uid}_web. Only the owning user may read/write their token.
    match /user_tokens/{tokenDoc} {
      allow read:   if isAuthenticated() && tokenDoc.matches(request.auth.uid + '.*');
      allow write:  if isAuthenticated() && tokenDoc.matches(request.auth.uid + '.*');
    }

    // ── Наставнички форум (forum_threads) ──
    // Автентицирани наставници можат да читаат и создаваат нишки.
    // Update is field-scoped rather than a single owner-or-admin gate, because a thread is
    // legitimately mutated by people other than its author: any teacher upvoting/reacting,
    // any teacher whose reply bumps replyCount/participantUids, not just the original author.
    // isPinned/moderationStatus are deliberately admin-only — NOT included in the author's
    // own editable-fields set below, closing a prior gap where an author could self-pin or
    // self-approve their own thread by writing those fields directly.
    match /forum_threads/{threadId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.authorUid == request.auth.uid;
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (resource.data.authorUid == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'body', 'editedAt', 'deleted', 'hasBestAnswer'])) ||
        isSelfArrayToggle('upvotedBy') ||
        isSelfArrayToggle('reactionsHelpful') ||
        isSelfArrayToggle('reactionsSame') ||
        isSelfArrayToggle('reactionsGreat') ||
        isForumReplyBump() ||
        isForumThreadReport()
      );
      allow delete: if isAdmin();
    }

    // ── Одговори на нишките (forum_replies) ──
    // Автентицирани наставници можат да читаат и создаваат одговори.
    // isBestAnswer/feynmanBadge are set by the PARENT THREAD's author on someone ELSE's
    // reply (markBestAnswer/toggleFeynmanBadge) — not a self-action, so they get their own
    // isForumThreadAuthorOf() branch rather than the reply-author-only edit branch.
    match /forum_replies/{replyId} {
      allow read:   if isAuthenticated();
      // 'ai-expert' is a sentinel UID for AI-generated replies posted by authenticated teachers
      allow create: if isAuthenticated() && (
        request.resource.data.authorUid == request.auth.uid ||
        request.resource.data.authorUid == 'ai-expert'
      );
      allow update: if isAuthenticated() && (
        isAdmin() ||
        ((resource.data.authorUid == request.auth.uid || resource.data.authorUid == 'ai-expert') &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['body', 'editedAt'])) ||
        isSelfArrayToggle('upvotedBy') ||
        isSelfArrayToggle('reactionsHelpful') ||
        isSelfArrayToggle('reactionsSame') ||
        isSelfArrayToggle('reactionsGreat') ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isBestAnswer']) && isForumThreadAuthorOf(resource.data.threadId)) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['feynmanBadge']) && isForumThreadAuthorOf(resource.data.threadId)) ||
        isForumReplyReport()
      );
      allow delete: if isAdmin();
    }

    // ── Матура испити (matura_exams) ──
    // Read: any authenticated user (students + teachers).
    // Write: admin, school_admin, or teacher (import pipeline via MaturaImportView).
    match /matura_exams/{examId} {
      allow read:           if isAuthenticated();
      allow create, update: if isAuthenticated() && (isAdmin() || isRole('school_admin') || isRole('teacher'));
      allow delete:         if isAdmin();
    }

    // ── Матура прашања (matura_questions) ──
    // Same access model as matura_exams — keyed by {examId}_{qN}.
    match /matura_questions/{docId} {
      allow read:           if isAuthenticated();
      allow create, update: if isAuthenticated() && (isAdmin() || isRole('school_admin') || isRole('teacher'));
      allow delete:         if isAdmin();
    }

    // ── Кеширани AI оценки за матура (matura_ai_grades) ──
    // Direct client writes are denied — the cache key is a deterministic hash of
    // (examId, questionNumber, answer), so a client could otherwise precompute the key for
    // their own wrong answer and write a fabricated grade before ever submitting it. All
    // grading + cache writes now go through /api/matura-grade (Admin SDK) instead.
    match /matura_ai_grades/{cacheKey} {
      allow read:           if isAuthenticated();
      allow create, update: if false;
      allow delete:         if isAdmin();
    }

    // ── Вектор ембединзи на концепти (concept_embeddings) — AI1 ──
    // Read: сите автентицирани; Write: само admin (индексирање преку Admin Portal).
    match /concept_embeddings/{conceptId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Решенија на заедницата за матура (matura_community_solutions) — М3 ──
    match /matura_community_solutions/{solutionId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.authorUid == request.auth.uid;
      // Upvote/un-upvote toggle: only the caller's own uid may be added/removed from
      // upvoterUids, and `upvotes` must move in lockstep by exactly the same +1/-1 — prevents
      // any authenticated caller from setting the count to an arbitrary value directly.
      allow update: if isAuthenticated() && (
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes', 'upvoterUids']) &&
         (
           (request.resource.data.upvoterUids.size() == resource.data.get('upvoterUids', []).size() + 1 &&
            request.resource.data.upvoterUids.hasAll(resource.data.get('upvoterUids', [])) &&
            request.resource.data.upvoterUids.hasAny([request.auth.uid]) &&
            request.resource.data.upvotes == (resource.data.get('upvotes', 0)) + 1) ||
           (request.resource.data.upvoterUids.size() == resource.data.get('upvoterUids', []).size() - 1 &&
            resource.data.get('upvoterUids', []).hasAll(request.resource.data.upvoterUids) &&
            !request.resource.data.upvoterUids.hasAny([request.auth.uid]) &&
            request.resource.data.upvotes == (resource.data.get('upvotes', 0)) - 1)
         )) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── Матурски задачи (matura_assignments) ──
    // Создавање: само наставник (не анонимен).
    // Читање: наставникот-создавач или ученик во тој класот (verified via classId query).
    //   Практично: дозволуваме read на сите автентицирани — класот е знаен само на ученикот.
    // Бришење: само наставникот или admin.
    match /matura_assignments/{assignmentId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated()
                    && !isAnonymousStudent()
                    && request.resource.data.teacherUid == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.teacherUid == request.auth.uid || isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.teacherUid == request.auth.uid || isAdmin()
      );
    }

    // ── Дига тестови (dugga_tests) ──
    // Читање: сите автентицирани (вклучувајќи анонимни ученици — им треба за пронаоѓање по код).
    // Создавање/уредување/бришење: само сопственичкиот наставник или admin.
    match /dugga_tests/{testId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated()
                    && !isAnonymousStudent()
                    && request.resource.data.teacherUid == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.teacherUid == request.auth.uid || isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.teacherUid == request.auth.uid || isAdmin()
      );
    }

    // ── Дига поднесувања (dugga_submissions) ──
    // Создавање: ученикот (анонимен или Google) — мора да го постави сопствениот studentUid.
    // Читање: ученикот (сопственик на поднесувањето) или наставникот (сопственик на тестот) или admin.
    // Уредување: само наставникот или admin (за рачна оценка / AI белешки).
    // Бришење: само admin.
    match /dugga_submissions/{subId} {
      allow read:   if isAuthenticated() && (
        resource.data.studentUid == request.auth.uid ||
        resource.data.teacherUid == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated()
                    && request.resource.data.studentUid == request.auth.uid
                    && request.resource.data.keys().hasAll(['testId', 'teacherUid', 'studentUid', 'studentName', 'score', 'totalPoints', 'percentage'])
                    // Bounds only — this can't verify the score is actually correct for the
                    // test's real questions (that would need server-side re-grading), but it
                    // closes the trivial "fabricate an out-of-range 100%" case.
                    && request.resource.data.score is number && request.resource.data.score >= 0
                    && request.resource.data.totalPoints is number && request.resource.data.totalPoints > 0
                    && request.resource.data.score <= request.resource.data.totalPoints
                    && request.resource.data.percentage is number
                    && request.resource.data.percentage >= 0 && request.resource.data.percentage <= 100;
      allow update: if isAuthenticated() && (
        resource.data.teacherUid == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── QR решенија (solution_uploads) ──
    // Токен (UUID) важи 10 мин. Само записот кој сè уште не е истечен може да добие imageUrl.
    // Читање: сите автентицирани — потребно за верификација на токенот од мобилен.
    // Создавање: автентицираниот корисник кој ја генерира (desktop или server).
    // Ажурирање: само полето imageUrl (мобилен ученик по прикачување).
    match /solution_uploads/{token} {
      allow read:   if isAuthenticated();
      // 2026-07-18 (audit_2026_07_18_full_app_review, security finding): expiresAt was fully
      // client-controlled — a caller could set it far in the future and keep exploiting the
      // update rule's own `resource.data.expiresAt > request.time.toMillis()` check indefinitely,
      // defeating the documented "10-minute token" design. The real client
      // (services/firestoreService.solutionUploads.ts) always sets exactly now+10min; bounded
      // here to now+11min (1min slack for clock skew) as a server-side ceiling.
      allow create: if isAuthenticated()
                    && request.resource.data.keys().hasAll(['questionKey', 'expiresAt', 'imageUrl', 'createdAt'])
                    && request.resource.data.expiresAt > request.time.toMillis()
                    && request.resource.data.expiresAt <= request.time.toMillis() + (11 * 60 * 1000);
      allow update: if isAuthenticated()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['imageUrl'])
                    && request.resource.data.imageUrl is string
                    && resource.data.expiresAt > request.time.toMillis();
      allow delete: if isAdmin();
    }

    // ── Бanka на сценаријa (scenario_bank) — S88 ──
    // Јавни сценаријата (isPublic=true) читаат сите автентицирани.
    // Само авторот или admin може да уредува/брише; заедничките акции (оценка,
    // зачувување, forkCount, usageCount) се дозволени за сите автентицирани наставници.
    match /scenario_bank/{docId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated() && !isAnonymousStudent()
                    && request.resource.data.authorUid == request.auth.uid;
      // Community actions (rating, saving, fork/usage counters) are open to any authenticated
      // teacher, but each is scoped so a caller can only ever touch their OWN contribution —
      // `deleted`/`isFeatured` are moderation-level and restricted to author/admin above.
      allow update: if isAuthenticated() && (
        resource.data.authorUid == request.auth.uid ||
        isAdmin() ||
        // Rating: only the caller's own key in ratingsByUid may change, value 1-5.
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ratingsByUid']) &&
         request.resource.data.ratingsByUid.diff(resource.data.get('ratingsByUid', {})).affectedKeys().hasOnly([request.auth.uid]) &&
         request.resource.data.ratingsByUid[request.auth.uid] is int &&
         request.resource.data.ratingsByUid[request.auth.uid] >= 1 &&
         request.resource.data.ratingsByUid[request.auth.uid] <= 5) ||
        // Save/unsave toggle: only the caller's own uid may be added/removed from savedByUids.
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['savedByUids']) &&
         (
           (request.resource.data.savedByUids.size() == resource.data.get('savedByUids', []).size() + 1 &&
            request.resource.data.savedByUids.hasAll(resource.data.get('savedByUids', [])) &&
            request.resource.data.savedByUids.hasAny([request.auth.uid])) ||
           (request.resource.data.savedByUids.size() == resource.data.get('savedByUids', []).size() - 1 &&
            resource.data.get('savedByUids', []).hasAll(request.resource.data.savedByUids) &&
            !request.resource.data.savedByUids.hasAny([request.auth.uid]))
         )) ||
        // Fork/usage counters: +1 exactly per call.
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['forkCount']) &&
         request.resource.data.forkCount == (resource.data.forkCount is number ? resource.data.forkCount : 0) + 1) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usageCount']) &&
         request.resource.data.usageCount == (resource.data.usageCount is number ? resource.data.usageCount : 0) + 1)
      );
      allow delete: if isAdmin();
    }

    // ── Колаборативни планови (collab_plans) — S88+ ──
    // Сопственикот, explicit collaborators (sharedWithUids), или token-based (publicLink=true).
    match /collab_plans/{planId} {
      allow read:   if isAuthenticated() && (
        resource.data.ownerUid == request.auth.uid ||
        (resource.data.sharedWithUids != null && request.auth.uid in resource.data.sharedWithUids) ||
        resource.data.publicLink == true ||
        isAdmin()
      );
      allow create: if isAuthenticated() && !isAnonymousStudent()
                    && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.ownerUid == request.auth.uid ||
        (resource.data.sharedWithUids != null && request.auth.uid in resource.data.sharedWithUids) ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.ownerUid == request.auth.uid || isAdmin()
      );
    }

    // ── Referrals (referrals) — S65 P3-B ──
    // Document ID = newUserUid. Created once by the new user during signup.
    // bonusGranted is flipped by a Cloud Function trigger (server-side credit
    // bump on `users/{refCode}.aiCreditsBalance`); clients cannot mutate it.
    match /referrals/{newUid} {
      allow read:   if isOwner(newUid) || isAdmin();
      allow create: if isOwner(newUid)
                    && request.resource.data.newUserUid == newUid
                    && request.resource.data.refCode is string
                    && request.resource.data.refCode != newUid
                    && request.resource.data.bonusGranted == false;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Curriculum overlays (teacher notes per topic) — S93-D ──
    // Doc ID: {uid}_{gradeId}_t{topicIndex}
    match /curriculum_overlays/{docId} {
      allow read:   if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid || isAdmin();
    }

    // ── Weekly plans — S93-C ──
    // Doc ID: {uid}_{gradeId}_w{weekNumber}
    match /weekly_plans/{docId} {
      allow read:   if isAuthenticated() && (
        resource.data.uid == request.auth.uid ||
        (resource.data.sharedWithUids != null && resource.data.sharedWithUids.hasAny([request.auth.uid])) ||
        resource.data.publicLink == true
      );
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.uid == request.auth.uid ||
        (resource.data.sharedWithUids != null && resource.data.sharedWithUids.hasAny([request.auth.uid]))
      );
      allow delete: if (isAuthenticated() && resource.data.uid == request.auth.uid) || isAdmin();
    }

    // ── Thematic plan edits — S73+ ──
    // Doc ID: {uid}_{gradeId}_{topicId}
    match /thematic_plan_edits/{docId} {
      allow read:   if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid || isAdmin();
    }

    // ── Scenario observations (ObservationModal + LessonStudyView) — S91/S93/S100 ──
    // Read: any authenticated teacher can read (observations are collaborative/public teaching records)
    // Write: only the author of the observation
    match /scenario_observations/{docId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.authorUid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.authorUid == request.auth.uid;
      allow delete: if (isAuthenticated() && resource.data.authorUid == request.auth.uid) || isAdmin();
    }

    // ── Lesson executions (ClassroomView post-class records) — S98+ ──
    match /lesson_executions/{docId} {
      allow read:   if isAuthenticated() && resource.data.teacherUid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid;
      allow delete: if (isAuthenticated() && resource.data.teacherUid == request.auth.uid) || isAdmin();
    }

    // ── Gamma Live sessions (gammaLiveService) — S88+ ──
    // PIN-based. Previously `update`/`responses` write were wide open to any authenticated
    // caller — any student (or anyone else) could overwrite the host's session state or another
    // student's response doc. Same bug class already fixed for live_sessions, scoped here the
    // same way: host owns the session doc, a student may only self-toggle `handsUids` or write
    // their own `responses/{uid}` doc (GammaStudentView.tsx's useStudentId() now returns a real
    // Firebase Auth uid via signInAnonymously, not a client-generated random string, so
    // request.auth.uid == studentId is finally a meaningful check).
    match /live_gamma/{pin} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated() && !isAnonymousStudent() && request.resource.data.hostUid == request.auth.uid;
      allow update: if isAuthenticated() && (
        isOwner(resource.data.hostUid) ||
        isSelfArrayToggle('handsUids') ||
        // responseCount is a display-only counter always reset to 0 by the client after a
        // submit (gammaLiveService.ts submitGammaResponse) — the real count comes from the
        // responses subcollection below, so this field doesn't need per-user scoping.
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['responseCount'])
      );
      allow delete: if isAdmin();

      match /responses/{studentId} {
        allow read:   if isAuthenticated();
        allow create, update: if isAuthenticated() && request.auth.uid == studentId;
        allow delete: if isAdmin();
      }
    }

    // Teacher's own saved Gamma presentations — auto-saved by GammaModeModal on mount
    // (2026-07-12), gives the /gamma library route something to list. Owner-scoped, same
    // pattern as most other "my saved X" collections in this app.
    match /gamma_presentations/{id} {
      allow read, update, delete: if isOwner(resource.data.teacherUid) || isAdmin();
      allow create: if isAuthenticated() && !isAnonymousStudent() && request.resource.data.teacherUid == request.auth.uid;
    }

    // ── Matura spaced rep — S68+ ──
    match /matura_spaced_rep/{docId} {
      allow read, write: if isAuthenticated() && request.auth.uid == docId.split('_')[0];
    }

    // ── Academy SM2 cards — S83+ ──
    match /academy_sm2/{docId} {
      allow read, write: if isAuthenticated() && request.auth.uid == docId.split('_')[0];
    }

    // ── Upload draft queue (scenario_upload_drafts) — S106+ ──
    // Doc ID = uid. Only the owning teacher may read/write their own draft queue.
    match /scenario_upload_drafts/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── Cognitive telemetry (anonymous learning analytics) — S83+ ──
    match /cognitive_telemetry/{docId} {
      allow create: if isAuthenticated();
      allow read:   if isAdmin();
      allow update, delete: if false;
    }

    // ── Зачувани презентации (saved_presentations) ──
    match /saved_presentations/{doc} {
      allow read, update, delete: if isAuthenticated() && (resource.data.teacherUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid;
    }

    // ── ZPD adaptive difficulty calibration (adaptive_difficulty/{teacherUid}/students/{key}) ──
    match /adaptive_difficulty/{teacherUid} {
      match /students/{key} {
        allow read, write: if isOwner(teacherUid) || isAdmin();
      }
    }

    // ── Scan artifacts (vision/homework extraction archive) ──
    match /scan_artifacts/{doc} {
      allow read, update, delete: if isAuthenticated() && (resource.data.teacherUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid;
    }

    // ── National benchmark (opt-in anonymous class-performance aggregate) — Ж6.4 ──
    // Doc ID = teacherUid. No student PII — safe to be broadly readable by any authenticated teacher.
    match /national_benchmark/{teacherUid} {
      allow read: if isAuthenticated();
      allow write: if isOwner(teacherUid);
    }

    // ── Academy public badges (denormalized summary of completed specializations) ──
    // Doc ID = uid. Only specialization IDs — no XP, no lesson-level detail, no
    // reflections (those stay self-only under users/{uid}/academy/progress).
    // Shown next to a teacher's name elsewhere in the app (Scenario Bank, Forum).
    match /academy_badges/{uid} {
      allow read: if isAuthenticated();
      allow write: if isOwner(uid);
    }

    // ── School B2B inquiry (public lead-capture form, /school-pricing) ──
    // Unauthenticated by design — pre-signup. Write-only from the client; only admins read leads.
    match /school_inquiries/{doc} {
      allow create: if request.resource.data.keys().hasAll(['schoolName', 'teacherCount']);
      allow read, update, delete: if isAdmin();
    }

    // ── School registry outreach log (admin tool tracking contacted schools from
    // data/schoolRegistry.ts, keyed by registry id) — admin-only both ways. ──
    match /school_outreach_log/{registryId} {
      allow read, write: if isAdmin();
    }

    // ── Grade books (saved gradebook snapshots) ──
    match /grade_books/{doc} {
      allow read, update, delete: if isAuthenticated() && (resource.data.teacherUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.teacherUid == request.auth.uid;
    }

    // Сè друго: одбиено
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
