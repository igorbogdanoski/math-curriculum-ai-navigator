    "canvas-confetti": "^1.9.4",
    "docx": "^9.6.0",
    "dompurify": "^3.3.3",
    "file-saver": "^2.0.5",
    "firebase": "^11.4.0",
    "html2canvas": "^1.4.1",
    "idb": "^8.0.3",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.563.0",
