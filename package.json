{
  "name": "math-curriculum-ai-navigator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "perf:budget": "node scripts/enforce-perf-budget.mjs",
    "backup:readiness-check": "node scripts/check-backup-readiness.mjs",
    "obs:incident-summary": "node scripts/sentry-incident-summary.mjs",
    "eval:validate-schema": "node scripts/run-eval.mjs --validate-schema",
    "eval:run": "node scripts/run-eval.mjs --outputs",
    "eval:smoke-gate": "node scripts/run-eval.mjs --outputs eval/sample-outputs.json --only-provided --min-score 70 --fail-below",
    "eval:show-trend": "node scripts/run-eval.mjs --show-trend",
      "prompts:check": "node scripts/hash-prompts.mjs --check",
      "prompts:update": "node scripts/hash-prompts.mjs --update",
      "prompts:list": "node scripts/hash-prompts.mjs --list",
    "preview": "vite preview",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky",
    "vercel:env:push": "node scripts/vercel-env-push.mjs",
    "vercel:env:dry": "node scripts/vercel-env-push.mjs --dry-run"
  },
  "dependencies": {
