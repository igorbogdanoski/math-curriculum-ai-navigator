    {
      "questionNumber": 23,
      "part": 3,
      "points": 4,
      "questionType": "open",
      "questionText": "Eğer $x \\neq -\\frac{1}{2}$ ve $x \\neq 0$ ise $\\left( \\frac{1-2x}{3+6x} + 2x - 1 \\right) : \\frac{1-2x}{1+2x} - \\frac{6x^2-2x}{3x}$ ifadesini basitleştirin.",
      "choices": null,
      "correctAnswer": "-4x",
      "topic": "Рационални изрази",
      "topicArea": "algebra",
      "dokLevel": 3,
      "hasImage": false,
      "imageUrls": [],
      "imageDescription": null,
      "conceptIds": [],
      "hints": [],
      "aiSolution": "$\\left( \\frac{1-2x}{3(1+2x)} + \\frac{(2x-1)3(1+2x)}{3(1+2x)} \\right) \\cdot \\frac{1+2x}{1-2x} - \\frac{2x(3x-1)}{3x} = \\frac{1-2x + 3(4x^2-1)}{3(1+2x)} \\cdot \\frac{1+2x}{1-2x} - \\frac{2(3x-1)}{3} = \\frac{12x^2-2x-2}{3(1-2x)} - \\frac{6x-2}{3} = \\frac{-2(1-2x)(3x+1)}{3(1-2x)} - \\frac{6x-2}{3} = \\frac{-6x-2-6x+2}{3} = -4x$.",
      "successRatePercent": null
    },
