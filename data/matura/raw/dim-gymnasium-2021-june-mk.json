    { "questionNumber": 31, "part": 3, "points": 4, "questionType": "open", "questionText": "[Текстот недостасува — само клуч]", "choices": null, "correctAnswer": "2", "topic": "Рационални изрази", "topicArea": "algebra", "dokLevel": 3, "hasImage": false, "imageUrls": [], "imageDescription": null, "conceptIds": [], "hints": [], "aiSolution": "Ги разложува броителите и именителите на дропките на прости множители. Ги сведува дропките во заградата на заеднички именител и одзема. Го запишува броителот на првата дропка како бином на квадрат, а потоа крати. Ги собира добиените дропки, извлекува пред заграда во броителот и крати, со што го добива резултатот 2.", "successRatePercent": null },
    { "questionNumber": 32, "part": 3, "points": 4, "questionType": "open", "questionText": "[Текстот недостасува — само клуч]", "choices": null, "correctAnswer": "C = \\{1,2,3,4\\}", "topic": "Линеарни неравенки", "topicArea": "algebra", "dokLevel": 3, "hasImage": false, "imageUrls": [], "imageDescription": null, "conceptIds": [], "hints": [], "aiSolution": "Ја трансформира првата неравенка до облик $x \\le 9/2$. Ја трансформира втората неравенка до облик $x > -4/5$. Го определува пресекот: $x \\in (-4/5, 9/2]$. Множеството $C = \\{1,2,3,4\\}$.", "successRatePercent": null },
    { "questionNumber": 33, "part": 3, "points": 4, "questionType": "open", "questionText": "[Текстот недостасува — само клуч]", "choices": null, "correctAnswer": "c = 40", "topic": "Пропорции", "topicArea": "algebra", "dokLevel": 3, "hasImage": false, "imageUrls": [], "imageDescription": null, "conceptIds": [], "hints": [], "aiSolution": "Ги означува деловите $a=2t, b=3t, c=5t, d=6t$. Од $a+b+c+d=128$ добива $t=8$. Па $c=40$.", "successRatePercent": null },
    { "questionNumber": 34, "part": 3, "points": 5, "questionType": "open", "questionText": "[Текстот недостасува — само клуч]", "choices": null, "correctAnswer": "А. m=26, m=10; Б. m=2; В. m=16", "topic": "Квадратни равенки", "topicArea": "algebra", "dokLevel": 3, "hasImage": false, "imageUrls": [], "imageDescription": null, "conceptIds": [], "hints": [], "aiSolution": "Трансформира во $8x^2-(m-2)x+m-8=0$. А. $D=0 \\Rightarrow m_1=26, m_2=10$. Б. $x_1=-x_2 \\Rightarrow m=2$. В. $x_1 x_2=1 \\Rightarrow m=16$.", "successRatePercent": null },
