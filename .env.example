# Google Gemini API Key
# Get it from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Firebase Configuration
# Get these from your Firebase Console -> Project Settings
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Firebase App Check (reCAPTCHA Enterprise Site Key)
VITE_RECAPTCHA_SITE_KEY=your_site_key_here

# Vertex AI Backend Credentials (Base64 encoded Service Account JSON)
# For local dev, you can use the path to the JSON file, but Base64 is preferred for Vercel
GOOGLE_APPLICATION_CREDENTIALS_BASE64=your_base64_string_here

# Sentry Application Monitoring (optional — leave empty to disable)
# Get DSN from: https://sentry.io → Your Project → Settings → Client Keys (DSN)
VITE_SENTRY_DSN=

# Sentry source maps upload (build-time, NOT exposed to browser)
# Get from: https://sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=
SENTRY_ORG=math-nav-org
SENTRY_PROJECT=math-nav

# Firebase Cloud Messaging — Web Push (optional — enables push notifications)
# Get from: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
# Click "Generate key pair" and copy the Key Pair value
VITE_FCM_VAPID_KEY=

# ─── VERCEL SERVERLESS FUNCTIONS (server-side only, NOT prefixed with VITE_) ──

# Firebase Admin SDK — required by api/create-school.ts (Н3)
# How to get:
#   1. Firebase Console → Project Settings → Service Accounts
#   2. "Generate new private key" → downloads JSON file
#   3. Encode to base64:  base64 -w 0 service-account.json   (Linux/Mac)
#      Or on Windows:    [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json"))
#   4. Paste the base64 string below (single long line, no spaces)
FIREBASE_SERVICE_ACCOUNT=your_base64_encoded_service_account_json

# CORS — allowed origin for serverless API responses
# Production should use the custom domain. Multiple origins may be provided comma-separated if needed.
ALLOWED_ORIGIN=https://ai.mismath.net

# GitHub Actions summary for SLO dashboard (server-side only)
# Use a token with read access to Actions metadata for the repository.
GITHUB_TOKEN=
GITHUB_REPO=igorbogdanoski/math-curriculum-ai-navigator

# Sentry incident summary for SLO dashboard (server-side only)
# These are separate from the build-time source map variables above.
# They are used by /api/slo-summary to aggregate production health.
# Example values depend on your Sentry org/project slugs.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=math-nav-org
# SENTRY_PROJECT=math-nav

# ─── STRIPE (Н2 — Billing) ────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Use "sk_test_..." for testing, "sk_live_..." for production
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE

# Get from: Stripe Dashboard → Products → Create Product → Add Price → copy Price ID
# Format: price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRO_PRICE_ID=price_YOUR_PRICE_ID_HERE

# Get from: Stripe Dashboard → Developers → Webhooks → Add endpoint
#   Endpoint URL: https://your-vercel-app.vercel.app/api/stripe-webhook
#   Events to listen: checkout.session.completed
#   After creation, reveal "Signing secret" (starts with whsec_)
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ─── DEMO MODE (Н3 — MON Presentation environment) ───────────────────────────
# Set to "true" ONLY on the MON demo Vercel deployment.
# Shows amber DemoBanner. Never set on production.
VITE_DEMO_MODE=false

# ─── S36-B5: Vertex AI Shadow A/B Rollout ────────────────────────────────────
# Fraction of requests (0.0–1.0) that get an automatic shadow call even when the
# manual toggle is off. Default 10% (0.10). Set to 0 to disable auto-rollout.
VITE_VERTEX_SHADOW_ROLLOUT_PERCENT=0.10

# ─── S36-B4: Cost-guard alert channels (all optional) ────────────────────────
# Slack incoming webhook URL — if set, sends alert when a user exceeds daily token budget.
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=

# Resend API key — if set together with ALERT_EMAIL, sends email alert on cost breach.
# Get from: https://resend.com/api-keys
RESEND_API_KEY=

# Email address to receive cost-guard alerts (requires RESEND_API_KEY)
ALERT_EMAIL=bogdanoskiigor@gmail.com
