# Google Gemini API Key
# Get it from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Firebase Configuration
# Get these from your Firebase Console -> Project Settings
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Firebase App Check (reCAPTCHA Enterprise Site Key)
VITE_RECAPTCHA_SITE_KEY=your_site_key_here

# Vertex AI Backend Credentials (Base64 encoded Service Account JSON)
# For local dev, you can use the path to the JSON file, but Base64 is preferred for Vercel
GOOGLE_APPLICATION_CREDENTIALS_BASE64=your_base64_string_here

# Sentry Application Monitoring (optional — leave empty to disable)
# Get DSN from: https://sentry.io → Your Project → Settings → Client Keys (DSN)
VITE_SENTRY_DSN=

# Sentry source maps upload (build-time, NOT exposed to browser)
# Get from: https://sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=
SENTRY_ORG=math-nav-org
SENTRY_PROJECT=math-nav

# Firebase Cloud Messaging — Web Push (optional — enables push notifications)
# Get from: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
# Click "Generate key pair" and copy the Key Pair value
VITE_FCM_VAPID_KEY=
