{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": ".ts-node-out",
    "resolveJsonModule": true
  },
  "include": ["scripts/**/*.ts"]
}
