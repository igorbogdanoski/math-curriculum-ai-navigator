rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Помошни функции ──────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isPDF() {
      return request.resource.contentType == 'application/pdf';
    }

    function isAllowedFileType() {
      return isImage() || isPDF();
    }

    // Max 10MB за слики, 25MB за PDF
    function isWithinSizeLimit() {
      return (isImage() && request.resource.size <= 10 * 1024 * 1024)
          || (isPDF()   && request.resource.size <= 25 * 1024 * 1024);
    }

    // ── Кориснички профилни слики ─────────────────────────────
    // /user_avatars/{uid}/avatar.{ext}
    match /user_avatars/{uid}/{fileName} {
      allow read:  if true; // Јавно — потребно за приказ во заедницата
      allow write: if isOwner(uid)
                   && isImage()
                   && isWithinSizeLimit();
      allow delete: if isOwner(uid);
    }

    // ── Материјали прикачени од наставниците ──────────────────
    // /teacher_uploads/{uid}/{fileName}
    match /teacher_uploads/{uid}/{fileName} {
      allow read:  if isAuthenticated(); // Само автентицирани
      allow write: if isOwner(uid)
                   && isAllowedFileType()
                   && isWithinSizeLimit();
      allow delete: if isOwner(uid);
    }

    // ── PDF извози на годишни планови ─────────────────────────
    // /annual_plans/{uid}/{planId}.pdf
    match /annual_plans/{uid}/{planId} {
      allow read:  if isAuthenticated();
      allow write: if isOwner(uid)
                   && isPDF()
                   && isWithinSizeLimit();
      allow delete: if isOwner(uid);
    }

    // ── Слики за квизови (прикачени преку Gemini Vision) ──────
    // /quiz_images/{uid}/{imageId}
    match /quiz_images/{uid}/{imageId} {
      allow read:  if isOwner(uid);
      allow write: if isOwner(uid)
                   && isImage()
                   && request.resource.size <= 5 * 1024 * 1024; // Max 5MB за quiz слики
      allow delete: if isOwner(uid);
    }

    // ── Слики прикачени од наставник во квиз прашање (П4) ─────
    // /question-images/{uid}/{fileName}
    // Само сопственикот чита/пишува; јавно читање за студентите кои го играат квизот
    match /question-images/{uid}/{fileName} {
      allow read:  if isAuthenticated(); // ученици и наставници
      allow write: if isOwner(uid)
                   && isImage()
                   && request.resource.size <= 8 * 1024 * 1024; // Max 8MB
      allow delete: if isOwner(uid);
    }

    // ── Форум слики (AlgebraTiles / Shape3D export) ───────────
    // /forum-images/{uid}/{fileName}
    match /forum-images/{uid}/{fileName} {
      allow read:  if isAuthenticated(); // Видливо за сите наставници во форумот
      allow write: if isOwner(uid)
                   && isImage()
                   && request.resource.size <= 10 * 1024 * 1024; // Max 10MB
      allow delete: if isOwner(uid);
    }

    // ── AI генерирани илустрации (Imagen / Gemini Vision) ─────
    // /ai_illustrations/{fileName}
    // Се генерираат на страна на клиентот (geminiService.real.ts)
    // Нема uid во патеката — rate limiting е на AI proxy страна
    match /ai_illustrations/{fileName} {
      allow read:  if true; // Јавно — вградени во споделени материјали
      allow write: if isAuthenticated()
                   && isImage()
                   && request.resource.size <= 10 * 1024 * 1024;
      allow delete: if isAuthenticated(); // Само автентицирани
    }

    // ── Legacy профилни слики (GDPR delete патека) ────────────
    // /profilePictures/{uid} — стара патека, нема upload, само delete
    match /profilePictures/{uid} {
      allow read:  if isOwner(uid);
      allow write: if false; // Нема нов upload на оваа патека
      allow delete: if isOwner(uid);
    }

    // ── Јавна национална библиотека — само читање ─────────────
    // /national_library/{resourceId}
    match /national_library/{resourceId} {
      allow read:  if true; // Јавно
      allow write: if false; // Само преку Cloud Functions / Admin SDK
    }

    // ── Matura слики (2025 испитни слики) ─────────────────────
    // /matura/images/{year}/{session}/{fileName}
    match /matura/{allSubPaths=**} {
      allow read:  if true; // Јавно — испитни слики се дел од содржината
      allow write: if false; // Само преку Admin SDK (import pipeline)
    }

    // ── Блокирај сè останато ──────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
